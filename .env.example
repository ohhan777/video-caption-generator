OPENAI_API_KEY=sk-...

# Optional overrides
# Transcription: whisper-1 is currently the only OpenAI model that returns
# segment-level timestamps via verbose_json (needed for SRT output).
OPENAI_TRANSCRIBE_MODEL=whisper-1
# Translation: any chat model. gpt-4o is a strong default; for higher quality
# at higher cost, try a larger model (e.g. gpt-4-turbo) by setting it here.
OPENAI_TRANSLATE_MODEL=gpt-4o
